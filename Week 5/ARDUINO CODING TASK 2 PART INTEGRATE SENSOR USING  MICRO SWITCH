const int relay1 = 7;        // Extend
const int relay2 = 8;        // Retract
const int switchPin = 2;     // Micro switch
const int ledPin = 13;       // LED

void setup() 
{
  pinMode(relay1, OUTPUT);
  pinMode(relay2, OUTPUT);
  pinMode(switchPin, INPUT_PULLUP);
  pinMode(ledPin, OUTPUT);

  stopActuator();
  digitalWrite(ledPin, LOW);

  Serial.begin(9600);
}

void loop() 
{
  Serial.println("Extending actuator...");
  extendActuator();

  // Wait until the micro switch is pressed
  while (digitalRead(switchPin) == HIGH)
  {
    delay(10);
  }

  Serial.println("Target reached");
  stopActuator();

  digitalWrite(ledPin, HIGH);   // LED ON when target reached
  delay(1000);

  Serial.println("Retracting actuator...");
  retractActuator();
  delay(5000);                  // Adjust this based on your actuator speed

  stopActuator();
  digitalWrite(ledPin, LOW);    // LED OFF after retract

  Serial.println("Cycle complete");
  delay(3000);
}

void extendActuator()
{
  digitalWrite(relay1, HIGH);
  digitalWrite(relay2, LOW);
}

void retractActuator()
{
  digitalWrite(relay1, LOW);
  digitalWrite(relay2, HIGH);
}

void stopActuator()
{
  digitalWrite(relay1, LOW);
  digitalWrite(relay2, LOW);
}
