#include <Servo.h>


const int potPin = A0;
const int ledPin = 7;
const int servoPin = 9;


Servo myServo;


void setup() {
  Serial.begin(9600);
  pinMode(ledPin, OUTPUT);
  myServo.attach(servoPin);
}


void loop() {
  int adcValue = analogRead(potPin);
// Convert the value to an angle (0 - 180)
  int angle = map(adcValue, 0, 1023, 0, 180);




  // Move the servo
  myServo.write(angle);


  // Control LED
  if (angle > 90) {
    digitalWrite(ledPin, HIGH);
  } else {
    digitalWrite(ledPin, LOW);
  }


  // Send data to Python
  Serial.println(angle);


  delay(50);
}
